# Neon database connection string. Keep secret. Do not commit real value.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Comma-separated frontend origins. Use your Netlify URL after deployment.
ALLOWED_ORIGINS=http://localhost:5173

# Koyeb / runtime settings
MODEL_DIR=backend/models
ENABLE_RUNTIME_TRAINING=false

# Free-tier safety limits
DB_KEEP_DAYS=90
DB_MAX_ROWS_PER_SYMBOL=140
DB_MAX_TOTAL_ROWS=2500
MODEL_MAX_MB=95
